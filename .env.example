# Copy to .env and fill in values. Never commit .env.
# Generate secrets: openssl rand -hex 32
# Fork release version reported by GET /v1/health/ (overrides package metadata)
LETTA_VERSION=0.5.0
LETTA_POSTGRES_PASSWORD=
LETTA_SERVER_PASSWORD=
LETTA_ENCRYPTION_KEY=
# Provider trace logging (step metadata for debugging/billing joins)
LETTA_TRACK_PROVIDER_TRACE=true
# Postgres: metadata only (no full request_json/response_json blobs). Requires provider_trace_metadata table.
LETTA_TELEMETRY_PROVIDER_TRACE_PG_METADATA_ONLY=true
LETTA_EMBEDDING=
# Unified embedding for recall, messages, images, folder file ingest, and agents (set in docker-compose for the vision service)
LETTA_DEFAULT_EMBEDDING_HANDLE=openrouter/google/gemini-embedding-2
LETTA_EMBED_ALL_MESSAGES=true
# Vision model for three-tier image captions (OpenRouter model id: minimax/minimax-m3)
LETTA_IMAGE_CAPTION_MODEL_HANDLE=openrouter/minimax/minimax-m3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
# Host paths (optional; defaults suit local dev)
MINIO_DATA_PATH=./data/minio
# Production (sliver): MINIO_DATA_PATH=/data/letta-vision/minio
MODEL_OVERRIDES_DIR=./shared
LETTA_LLM_REQUEST_TIMEOUT_SECONDS=300
LETTA_LLM_STREAM_TIMEOUT_SECONDS=600
# Cap applied when creating agents without an explicit context_window_limit (set >= largest model you use)
GLOBAL_MAX_CONTEXT_WINDOW_LIMIT=1000000

# Optional Letta / provider configuration (see Letta server docs)
OPENROUTER_API_KEY=
# OpenRouter app attribution (dashboard name + rankings)
OPENROUTER_TITLE=letta-vision
OPENROUTER_REFERER=https://letta-vision.scenecraft.studio
E2B_API_KEY=
E2B_SANDBOX_TEMPLATE_ID=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
