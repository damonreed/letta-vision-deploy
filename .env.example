# Copy to .env and fill in values. Never commit .env.
# Generate secrets: openssl rand -hex 32
# Fork release version reported by GET /v1/health/ (overrides package metadata)
LETTA_VERSION=0.3.0
LETTA_POSTGRES_PASSWORD=
LETTA_SERVER_PASSWORD=
LETTA_EMBEDDING=
LETTA_LLM_REQUEST_TIMEOUT_SECONDS=300
LETTA_LLM_STREAM_TIMEOUT_SECONDS=600

# Optional Letta / provider configuration (see Letta server docs)
OPENROUTER_API_KEY=
E2B_API_KEY=
E2B_SANDBOX_TEMPLATE_ID=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
