# Copy to .env and fill in values. Never commit .env.
# Generate secrets: openssl rand -hex 32
# Fork release version reported by GET /v1/health/ (overrides package metadata)
LETTA_VERSION=0.5.0
LETTA_POSTGRES_PASSWORD=
LETTA_SERVER_PASSWORD=
LETTA_ENCRYPTION_KEY=
# Store redacted LLM traces only; set false to disable provider trace DB entirely
LETTA_TRACK_PROVIDER_TRACE=true
LETTA_EMBEDDING=
LETTA_DEFAULT_EMBEDDING_HANDLE=openrouter/google/gemini-embedding-2-preview
LETTA_EMBED_ALL_MESSAGES=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
LETTA_LLM_REQUEST_TIMEOUT_SECONDS=300
LETTA_LLM_STREAM_TIMEOUT_SECONDS=600
# Cap applied when creating agents without an explicit context_window_limit (set >= largest model you use)
GLOBAL_MAX_CONTEXT_WINDOW_LIMIT=1000000

# Optional Letta / provider configuration (see Letta server docs)
OPENROUTER_API_KEY=
# OpenRouter app attribution (dashboard name + rankings)
OPENROUTER_TITLE=letta-vision
OPENROUTER_REFERER=https://letta-vision.scenecraft.studio
E2B_API_KEY=
E2B_SANDBOX_TEMPLATE_ID=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
