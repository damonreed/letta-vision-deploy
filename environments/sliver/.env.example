# Sliver production overrides — copy these into deploy-root .env (never commit .env).
# Base template: ../../.env.example (secrets: openssl rand -hex 32)
#
# After pulling main into sliver:
#   git fetch && git checkout sliver && git merge origin/main
#   docker compose up -d --build
#
LETTA_VERSION=0.6.0-rc
MINIO_DATA_PATH=/data/letta-vision/minio
MODEL_OVERRIDES_DIR=./environments/sliver
LETTA_LLM_REQUEST_TIMEOUT_SECONDS=120
LETTA_LLM_STREAM_TIMEOUT_SECONDS=600
LETTA_DEFAULT_EMBEDDING_HANDLE=openrouter/google/gemini-embedding-2-preview
LETTA_EMBED_ALL_MESSAGES=true
OPENROUTER_TITLE=letta-vision
OPENROUTER_REFERER=https://letta-vision.scenecraft.studio
